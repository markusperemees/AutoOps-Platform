global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["alertmanager:9093"]

rule_files:
  - /etc/prometheus/alert-rules.yml

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: "alertmanager"
    static_configs:
      - targets: ["alertmanager:9093"]

  - job_name: "monitoring-node-exporter"
    static_configs:
      - targets: ["node-exporter:9100"]

  - job_name: "app-node-exporter"
    static_configs:
      - targets:
{% for host in groups.get('app', []) %}
          - "{{ hostvars[host].ansible_host }}:9100"
{% endfor %}

  - job_name: "app-cadvisor"
    static_configs:
      - targets:
{% for host in groups.get('app', []) %}
          - "{{ hostvars[host].ansible_host }}:8080"
{% endfor %}

  - job_name: "demo-app"
    metrics_path: /metrics
    static_configs:
      - targets:
{% for host in groups.get('app', []) %}
          - "{{ hostvars[host].ansible_host }}:5000"
{% endfor %}
