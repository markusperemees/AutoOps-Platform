services:
  podinfo:
    image: {{ podinfo_image }}
    container_name: podinfo
    restart: unless-stopped
    ports:
      - "5000:9898"

  node-exporter:
    image: {{ node_exporter_image }}
    container_name: app-node-exporter
    restart: unless-stopped
    ports:
      - "9100:9100"
    volumes:
      - "/:/host:ro,rslave"
    command:
      - "--path.rootfs=/host"

  cadvisor:
    image: {{ cadvisor_image }}
    container_name: cadvisor
    restart: unless-stopped
    privileged: true
    devices:
      - /dev/kmsg
    ports:
      - "8080:8080"
    volumes:
      - "/:/rootfs:ro"
      - "/var/run:/var/run:rw"
      - "/sys:/sys:ro"
      - "/var/lib/docker:/var/lib/docker:ro"
      - "/dev/disk:/dev/disk:ro"
    command:
      - "--housekeeping_interval=30s"
      - "--docker_only=true"
