services:
  prometheus:
    image: {{ prometheus_image }}
    container_name: prometheus
    restart: unless-stopped
    ports:
      - "9090:9090"
    volumes:
      - {{ monitoring_base_dir }}/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - {{ monitoring_base_dir }}/prometheus/alert-rules.yml:/etc/prometheus/alert-rules.yml:ro
      - {{ monitoring_base_dir }}/prometheus/data:/prometheus
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"

  alertmanager:
    image: {{ alertmanager_image }}
    container_name: alertmanager
    restart: unless-stopped
    ports:
      - "9093:9093"
    volumes:
      - {{ monitoring_base_dir }}/alertmanager/alertmanager.yml:/etc/alertmanager/alertmanager.yml:ro
      - {{ monitoring_base_dir }}/alertmanager/data:/alertmanager
    command:
      - "--config.file=/etc/alertmanager/alertmanager.yml"
      - "--storage.path=/alertmanager"

  grafana:
    image: {{ grafana_image }}
    container_name: grafana
    restart: unless-stopped
    ports:
      - "3000:3000"
    environment:
      GF_SECURITY_ADMIN_USER: "{{ grafana_admin_user }}"
      GF_SECURITY_ADMIN_PASSWORD: "{{ grafana_admin_password }}"
    volumes:
      - {{ monitoring_base_dir }}/grafana/data:/var/lib/grafana
      - {{ monitoring_base_dir }}/grafana/provisioning:/etc/grafana/provisioning
      - {{ monitoring_base_dir }}/grafana/dashboards:/var/lib/grafana/dashboards

  node-exporter:
    image: {{ node_exporter_image }}
    container_name: monitoring-node-exporter
    restart: unless-stopped
    ports:
      - "9100:9100"
    volumes:
      - "/:/host:ro,rslave"
    command:
      - "--path.rootfs=/host"
